---
// Import the default SocialIcons component from Starlight
import Default from "@astrojs/starlight/components/SocialIcons.astro";
---

<!-- Render the default social icons (GitHub, etc.) -->
<Default><slot /></Default>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
